# Application Environment
APP_ENV=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration (if needed)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Model Paths
MODEL_BASE_PATH=./models
ADAPTER_SPEC_PATH=config/adapter_spec_v55.json

# Cache Configuration
CACHE_SIZE=1000

# OOD Detection
OOD_THRESHOLD=25.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS
CORS_ORIGINS=*