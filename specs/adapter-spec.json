{
    "adapter_id":  "aads_multicrop_continual_v6",
    "architecture":  "continual_sd_lora",
    "version":  "6.0.0",
    "backbone":  {
                     "model_name":  "facebook/dinov3-vitl16-pretrain-lvd1689m",
                     "frozen":  true
                 },
    "quantization":  {
                         "mode":  "int8_hybrid",
                         "strict_backend":  true
                     },
    "adapter":  {
                    "target_modules_strategy":  "all_linear_transformer",
                    "lora_r":  16,
                    "lora_alpha":  32,
                    "lora_dropout":  0.1
                },
    "fusion":  {
                   "layers":  [
                                  2,
                                  5,
                                  8,
                                  11
                              ],
                   "output_dim":  768,
                   "dropout":  0.1,
                   "gating":  "softmax"
               },
    "ood_detection":  {
                          "method":  "continual_ensemble",
                          "score":  "0.6 * mahalanobis_z + 0.4 * energy_z",
                          "threshold_factor":  2
                      },
    "training":  {
                     "continual":  {
                                       "optimizer":  "AdamW",
                                       "learning_rate":  0.0001,
                                       "weight_decay":  0,
                                       "num_epochs":  3,
                                       "batch_size":  8
                                   }
                 },
    "targets":  {
                    "continual_accuracy":  0.93,
                    "ood_auroc":  0.92,
                    "ood_false_positive_rate":  0.05
                }
}

