{
  "version": "5.5.3",
  "description": "Test environment with comprehensive validation",
  
  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "workers": 1,
    "reload": true,
    "log_level": "debug"
  },
  
  "security": {
    "api_key_required": false,
    "api_keys": [],
    "rate_limit": {
      "requests_per_minute": 500,
      "burst": 1000
    },
    "max_request_size_mb": 15,
    "cors": {
      "allow_origins": ["http://localhost:3000", "http://localhost:8080"],
      "allow_credentials": true,
      "allow_methods": ["*"],
      "allow_headers": ["*"]
    },
    "https_enforced": false
  },
  
  "cache": {
    "enabled": true,
    "backend": "redis",
    "redis_url": "redis://localhost:6379",
    "ttl": 1800,
    "max_size": 500
  },
  
  "compression": {
    "enabled": true,
    "minimum_size": 512,
    "compression_level": 6
  },
  
  "monitoring": {
    "enabled": true,
    "prometheus": {
      "enabled": true,
      "port": 9090,
      "path": "/metrics"
    },
    "logging": {
      "format": "json",
      "rotate": true,
      "max_size_mb": 100,
      "backup_count": 5
    },
    "metrics": {
      "enabled": true,
      "track_requests": true,
      "track_latency": true,
      "track_errors": true,
      "track_cache": true,
      "track_ood": true,
      "track_gpu": true,
      "track_memory": true
    },
    "health": {
      "enabled": true,
      "detailed": true,
      "include_memory": true,
      "include_cuda": true
    }
  },
  
  "database": {
    "pool_size": 5,
    "max_overflow": 10,
    "pool_recycle": 1800,
    "pool_pre_ping": true
  }
}