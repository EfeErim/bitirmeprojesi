{
  "version": "5.5.3",
  "description": "Production optimizations with caching, rate limiting, and security",
  
  "api": {
    "host": "0.0.0.0",
    "port": 8000,
    "workers": 4,
    "reload": false,
    "log_level": "info"
  },
  
  "security": {
    "api_key_required": true,
    "api_keys": ["prod_key_secure_token_12345"],
    "rate_limit": {
      "requests_per_minute": 100,
      "burst": 200
    },
    "max_request_size_mb": 10,
    "cors": {
      "allow_origins": ["https://yourdomain.com"],
      "allow_credentials": true,
      "allow_methods": ["*"],
      "allow_headers": ["*"]
    },
    "https_enforced": true
  },
  
  "cache": {
    "enabled": true,
    "backend": "redis",
    "redis_url": "redis://localhost:6379",
    "ttl": 3600,
    "max_size": 1000
  },
  
  "compression": {
    "enabled": true,
    "minimum_size": 1024,
    "compression_level": 6
  },
  
  "monitoring": {
    "enabled": true,
    "prometheus": {
      "enabled": true,
      "port": 9090,
      "path": "/metrics"
    },
    "logging": {
      "format": "json",
      "rotate": true,
      "max_size_mb": 100,
      "backup_count": 5
    },
    "metrics": {
      "enabled": true
    },
    "health": {
      "enabled": true,
      "detailed": true,
      "include_memory": true,
      "include_cuda": true
    }
  },
  
  "database": {
    "pool_size": 20,
    "max_overflow": 30,
    "pool_recycle": 3600,
    "pool_pre_ping": true
  }
}