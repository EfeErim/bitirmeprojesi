{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AADS-ULoRA Base Configuration",
  "description": "Base configuration for Agricultural AI Development System - ULoRA v5.5",
  "version": "5.5.0",
  "last_updated": "2026-02-19",

  "training": {
    "enabled": true,
    "default_device": "cuda",
    "mixed_precision": true,
    "gradient_accumulation_steps": 4
  },

  "router": {
    "enabled": true,
    "type": "enhanced",
    "vlm": {
      "enabled": true,
      "strict_model_loading": false,
      "model_source": "huggingface",
      "pipeline_mode": "sam3",
      "confidence_threshold": 0.25,
      "open_set_enabled": true,
      "open_set_min_confidence": 0.25,
      "open_set_margin": 0.01,
      "max_detections": 50,
      "use_dynamic_taxonomy": true,
      "taxonomy_path": "config/plant_taxonomy.json",
      "model_ids": {
        "grounding_dino": "IDEA-Research/grounding-dino-base",
        "sam": "facebook/sam3",
        "bioclip": "imageomics/bioclip-2.5-vith14"
      },
      "sam3_text_prompt": "plant",
      "sam3_mask_threshold": 0.01,
      "min_box_area_ratio": 0.001,
      "min_box_side_px": 10,
      "classification_min_confidence": 0.20,
      "quality_score_weights": {
        "crop_confidence": 0.65,
        "part_confidence": 0.20,
        "sam3_score": 0.15
      },
      "prompt_templates": {
        "crop": [
          "a photo of {term}",
          "a {term} plant",
          "a {term} crop leaf",
          "a damaged {term}",
          "a {term} with disease",
          "a diseased {term} leaf",
          "an unhealthy {term}",
          "a close-up of {term}",
          "a macro photo of {term} foliage",
          "a {term} showing symptoms"
        ],
        "part": [
          "a photo of a plant {term}",
          "a plant {term}",
          "a {term} of a plant",
          "a {term} with disease",
          "a diseased plant {term}",
          "an unhealthy {term}",
          "a close-up of a plant {term}",
          "a macro photo of a {term}",
          "a {term} with spots",
          "a {term} showing lesions"
        ]
      },
      "part_to_crop_hints": {
        "tuber": ["potato", "yam", "cassava", "taro"],
        "bulb": ["onion", "garlic", "shallot", "leek"],
        "grain": ["wheat", "corn", "rice", "barley", "oat", "sorghum"],
        "ear": ["wheat", "corn", "sorghum"],
        "berry": ["grape", "blueberry", "strawberry", "raspberry", "blackberry"],
        "pod": ["bean", "pea", "soybean", "lentil"],
        "fruit": ["tomato", "potato", "pepper", "eggplant", "squash", "pumpkin", "cucumber", "melon"],
        "root": ["carrot", "beet", "turnip", "radish", "parsnip"],
        "_default": []
      },
      "ensemble_config": {
        "crop_num_prompts": 2,
        "part_num_prompts": 3,
        "confidence_margin_threshold": 0.7
      }
    },
    "crop_mapping": {
      "tomato": {
        "parts": ["leaf", "fruit", "stem", "whole"],
        "model_path": "models/tomato_adapter"
      },
      "potato": {
        "parts": ["leaf", "tuber", "stem", "whole"],
        "model_path": "models/potato_adapter"
      },
      "wheat": {
        "parts": ["leaf", "ear", "stem", "whole"],
        "model_path": "models/wheat_adapter"
      }
    },
    "fallback_strategy": "best_available",
    "confidence_threshold": 0.7
  },

  "ood": {
    "enabled": true,
    "method": "mahalanobis",
    "threshold": 0.95,
    "confidence_level": 0.99,
    "prototype": {
      "update_rate": 0.1,
      "min_samples": 10
    },
    "mahalanobis": {
      "eps": 1e-6,
      "batch_size": 64
    }
  },

  "logging": {
    "format": "json",
    "rotate": true,
    "max_size_mb": 100,
    "backup_count": 5
  }
}
