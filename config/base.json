{
  "training": {
    "continual": {
      "backbone": {
        "model_name": "facebook/dinov3-vitl16-pretrain-lvd1689m"
      },
      "adapter": {
        "target_modules_strategy": "all_linear_transformer",
        "lora_r": 16,
        "lora_alpha": 16,
        "lora_dropout": 0.1
      },
      "fusion": {
        "layers": [2, 5, 8, 11],
        "output_dim": 768,
        "dropout": 0.1,
        "gating": "softmax"
      },
      "ood": {
        "threshold_factor": 2.0,
        "primary_score_method": "auto",
        "ber_enabled": false,
        "ber_lambda_old": 0.1,
        "ber_lambda_new": 0.1,
        "ber_warmup_steps": 50,
        "energy_temperature_mode": "fixed",
        "energy_temperature": 1.0,
        "energy_temperature_range": [0.5, 3.0],
        "energy_temperature_steps": 16,
        "radial_l2_enabled": true,
        "radial_beta_range": [0.5, 2.0],
        "radial_beta_steps": 16,
        "knn_backend": "auto",
        "knn_chunk_size": 2048,
        "sure_enabled": true,
        "sure_semantic_percentile": 95.0,
        "sure_confidence_percentile": 90.0,
        "conformal_enabled": true,
        "conformal_alpha": 0.05,
        "conformal_method": "threshold",
        "conformal_raps_lambda": 0.0,
        "conformal_raps_k_reg": 1
      },
      "learning_rate": 0.0001,
      "weight_decay": 0.01,
      "num_epochs": 10,
      "batch_size": 8,
      "device": "cuda",
      "strict_model_loading": false,
      "seed": 42,
      "deterministic": true,
      "optimization": {
        "grad_accumulation_steps": 4,
        "max_grad_norm": 1.0,
        "mixed_precision": "auto",
        "label_smoothing": 0.0,
        "scheduler": {
          "name": "cosine",
          "warmup_ratio": 0.1,
          "min_lr": 1e-06,
          "step_on": "batch"
        }
      },
      "data": {
        "sampler": "shuffle",
        "loader_error_policy": "tolerant",
        "target_size": 224,
        "cache_size": 1000,
        "validate_images_on_init": true
      },
      "early_stopping": {
        "enabled": true,
        "metric": "val_loss",
        "mode": "min",
        "patience": 5,
        "min_delta": 0.0
      },
      "evaluation": {
        "best_metric": "val_loss",
        "emit_ood_gate": true,
        "require_ood_for_gate": true,
        "ood_fallback_strategy": "held_out_benchmark",
        "ood_benchmark_auto_run": true,
        "ood_benchmark_min_classes": 3
      }
    }
  },
  "router": {
    "enabled": true,
    "crop_mapping": {
      "tomato": {
        "parts": ["leaf", "fruit", "stem", "whole"]
      },
      "potato": {
        "parts": ["leaf", "tuber", "stem", "whole"]
      },
      "wheat": {
        "parts": ["leaf", "ear", "stem", "whole"]
      }
    },
    "vlm": {
      "enabled": true,
      "profile": "balanced",
      "strict_model_loading": false,
      "confidence_threshold": 0.25,
      "max_detections": 50,
      "open_set_enabled": true,
      "open_set_min_confidence": 0.25,
      "open_set_margin": 0.01,
      "use_dynamic_taxonomy": true,
      "sam3_text_prompt": "plant",
      "sam3_expand_with_supported_parts": true,
      "sam3_prompt_limit": 6,
      "policy_graph": {
        "crop_evidence": {
          "global_crop_context_enabled": true,
          "global_crop_context_weight": 0.65
        },
        "part_resolution": {
          "preferred_part_labels": [],
          "leaf_override_target_labels": ["whole plant", "whole", "plant", "entire plant"],
          "leaf_override_ratio": 0.9,
          "leaf_override_min_confidence": 0.16,
          "leaf_override_min_margin": 0.04,
          "leaf_visual_likeness_threshold": 0.58,
          "leaf_visual_green_min": 0.18,
          "leaf_visual_min_margin": 0.05,
          "leaf_visual_force_without_leaf_score": false,
          "leaf_part_rebalance_threshold": 0.52,
          "leaf_part_rebalance_penalty": 0.8,
          "leaf_part_rebalance_boost": 1.15,
          "leaf_part_rebalance_min_confidence": 0.18,
          "leaf_part_rebalance_support_ratio": 0.75
        }
      },
      "profiles": {
        "balanced": {
          "sam3_prompt_limit": 6,
          "ensemble_config": {
            "crop_num_prompts": 4,
            "part_num_prompts": 4
          }
        },
        "fast": {
          "sam3_prompt_limit": 4,
          "ensemble_config": {
            "crop_num_prompts": 2,
            "part_num_prompts": 2
          }
        }
      },
      "taxonomy_path": "config/plant_taxonomy.json",
      "model_ids": {
        "grounding_dino": "IDEA-Research/grounding-dino-base",
        "sam": "facebook/sam3",
        "bioclip": "imageomics/bioclip-2.5-vith14"
      }
    }
  },
  "ood": {
    "enabled": true,
    "method": "ensemble",
    "threshold_factor": 2.0,
    "primary_score_method": "auto",
    "radial_l2_enabled": true,
    "sure_enabled": true,
    "conformal_enabled": true,
    "conformal_alpha": 0.05,
    "conformal_method": "threshold",
    "energy_temperature": 1.0,
    "knn_backend": "auto"
  },
  "inference": {
    "adapter_root": "models/adapters",
    "lazy_load": true,
    "cache_enabled": false,
    "target_size": 224
  }
}
