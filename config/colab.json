{
  "title": "Google Colab Optimized Configuration for AADS-ULoRA",
  "description": "Optimized hyperparameters for training on Google Colab with 24GB GPU memory",
  "training": {
    "phase1": {
      "batch_size": 16,
      "gradient_accumulation_steps": 4,
      "learning_rate": 1e-4,
      "lora_r": 16,
      "lora_alpha": 16,
      "lora_dropout": 0.1,
      "loraplus_lr_ratio": 8,
      "num_epochs": 20,
      "early_stopping_patience": 5,
      "gradient_clip_norm": 1.0,
      "mixed_precision": true,
      "checkpoint_interval": 5,
      "warmup_steps": 500
    },
    "phase2": {
      "batch_size": 16,
      "gradient_accumulation_steps": 4,
      "learning_rate": 5e-5,
      "lora_r": 8,
      "lora_alpha": 8,
      "num_epochs": 15,
      "gradient_clip_norm": 1.0,
      "mixed_precision": true,
      "checkpoint_interval": 5
    },
    "phase3": {
      "batch_size": 16,
      "gradient_accumulation_steps": 4,
      "learning_rate": 5e-5,
      "lora_r": 8,
      "lora_alpha": 8,
      "num_epochs": 10,
      "gradient_clip_norm": 1.0,
      "mixed_precision": true,
      "checkpoint_interval": 5,
      "conec_temperature": 0.07,
      "conec_prototype_dim": 128,
      "conec_num_prototypes": 5
    }
  },
  "data_loading": {
    "num_workers": 2,
    "pin_memory": true,
    "prefetch_factor": 2,
    "cache_size": 500,
    "target_image_size": 224
  },
  "device": {
    "device": "cuda",
    "enable_amp": true,
    "cudnn_benchmark": true,
    "cudnn_deterministic": false
  },
  "ood": {
    "enabled": true,
    "method": "mahalanobis",
    "threshold": 0.95,
    "confidence_level": 0.99,
    "mahalanobis": {
      "eps": 1e-6,
      "batch_size": 32
    }
  },
  "monitoring": {
    "enabled": true,
    "log_interval": 50,
    "checkpoint_dir": "./checkpoints",
    "save_best_only": true,
    "save_last": true
  },
  "debugging": {
    "verbose": true,
    "log_gradients": false,
    "profile_memory": false
  }
}
