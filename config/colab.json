{
  "colab": {
    "enabled": true,
    "drive_mount_path": "/content/drive/MyDrive/aads_ulora",
    "workspace_path": "/content/aads_ulora",
    "paths": {
      "data_dir": "./data",
      "models_dir": "./models",
      "checkpoints_dir": "./checkpoints",
      "outputs_dir": "./outputs"
    },
    "training": {
      "pin_memory": true,
      "num_workers": 2,
      "checkpoint_every_n_steps": 200,
      "checkpoint_interval": 200,
      "checkpoint_on_exception": true,
      "stdout_progress_batch_interval": 50,
      "stdout_progress_min_interval_sec": 15.0
    }
  },
  "training": {
    "continual": {
      "num_epochs": 3,
      "batch_size": 8,
      "device": "cuda",
      "strict_model_loading": true,
      "data": {
        "validate_images_on_init": false
      }
    }
  },
  "router": {
    "vlm": {
      "profile": "fast",
      "strict_model_loading": true
    }
  },
  "inference": {
    "adapter_root": "models/adapters",
    "lazy_load": true,
    "cache_enabled": false,
    "target_size": 224
  }
}
