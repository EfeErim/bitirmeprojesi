{
  "config_schema_version": 1,
  "colab": {
    "enabled": true,
    "drive_mount_path": "/content/drive/MyDrive/aads_ulora",
    "workspace_path": "/content/aads_ulora",
    "paths": {
      "data_dir": "./data",
      "models_dir": "./models",
      "checkpoints_dir": "./checkpoints",
      "outputs_dir": "./outputs"
    },
    "training": {
      "pin_memory": true,
      "num_workers": 12,
      "validation_every_n_epochs": 2,
      "checkpoint_every_n_steps": 250,
      "checkpoint_on_exception": true,
      "stdout_progress_batch_interval": 12,
      "stdout_progress_min_interval_sec": 15.0
    }
  },
  "training": {
    "continual": {
      "num_epochs": 12,
      "batch_size": 96,
      "learning_rate": 0.0002,
      "device": "cuda",
      "strict_model_loading": true,
      "deterministic": false,
      "optimization": {
        "grad_accumulation_steps": 1,
        "mixed_precision": "bf16",
        "max_grad_norm": 1.0,
        "scheduler": {
          "name": "cosine",
          "warmup_ratio": 0.1,
          "min_lr": 1e-06,
          "step_on": "batch"
        }
      },
      "evaluation": {
        "ood_benchmark_min_classes": 3
      },
      "data": {
        "cache_size": 20000,
        "cache_train_split": true,
        "validate_images_on_init": false
      }
    }
  },
  "router": {
    "vlm": {
      "profile": "fast",
      "strict_model_loading": true
    }
  },
  "inference": {
    "adapter_root": "models/adapters",
    "lazy_load": true,
    "cache_enabled": false,
    "target_size": 224
  }
}
