{
  "version": "5.5.3",
  "description": "Configuration for OOD detection and uncertainty estimation",
  
  "ood": {
    "enabled": true,
    "method": "mahalanobis",
    "threshold": 0.95,
    "confidence_level": 0.99,
    
    "prototype": {
      "enabled": true,
      "update_rate": 0.1,
      "min_samples": 10,
      "max_prototypes": 1000,
      "distance_metric": "euclidean",
      "adaptive_threshold": true
    },
    
    "mahalanobis": {
      "enabled": true,
      "eps": 1e-6,
      "batch_size": 64,
      "use_shared_covariance": false,
      "regularization": 1e-5,
      "num_samples": 10000
    }
  }
}